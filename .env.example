# Required in production

# Secret key for signing HTTP-only session JWTs.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""


# Optional database

# Leave blank to use ./database/sqlite.db.
# PostgreSQL: postgresql://username:password@host:port/database_name?sslmode=require
# MySQL/MariaDB: mysql://username:password@host:port/database_name
DATABASE_URL=""


# Optional Redis document-read cache

# Standard Redis URL. Leave blank to read documents directly from the database.
# Examples: redis://localhost:6379/0, rediss://username:password@host:port/0
REDIS_URL=""
DOCUMENT_CACHE_TTL_SECONDS=""


# Optional S3-compatible image uploads

# When these values are blank, the editor keeps URL-based image insertion only.
S3_ENDPOINT=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_PUBLIC_BASE_URL=""
S3_FORCE_PATH_STYLE=""
IMAGE_UPLOAD_MAX_BYTES=""
MARKDOWN_IMPORT_MAX_BYTES=""
BACKUP_RESTORE_MAX_BYTES=""


# Optional development-only image storage

# Enabled by default only when NODE_ENV=development.
# This writes local WebP test uploads and serves them through /files/*.
DEV_IMAGE_STORAGE_ENABLED=""
DEV_IMAGE_STORAGE_DIR=""
DEV_IMAGE_PUBLIC_BASE_URL=""


# Optional app metadata

APP_NAME=""
APP_DESCRIPTION=""
APP_COVER_IMAGE=""
APP_LOGO=""
APP_ICON=""
VERSION_RETENTION_DAYS=""
