---
export const prerender = false;

import { Printer, ShieldAlert } from '@/components/Icons';
import Layout from '@/layouts/Layout.astro';
import { config } from '@/utils/config';
import { getCachedPublicDocument } from '@/utils/documentCache';
import { parseMarkdown } from '@/utils/markdown';

const { username, id } = Astro.params;

if (!username || !id) {
  return new Response('Not found', { status: 404 });
}

const { user: userObj, doc } = await getCachedPublicDocument(username, id);
const docExists = Boolean(doc);

// Handle redirect if accessed via UUID but has a custom slug
if (docExists && doc!.customSlug && id !== doc!.customSlug) {
  return Astro.redirect(`/${username}/documents/${doc!.customSlug}`, 301);
}

// Verify the document belongs to this user
const ownershipMatch = docExists && doc!.userId === userObj!.id;

const isAccessible =
  ownershipMatch && (doc!.visibility === 'public' || doc!.visibility === 'unlisted');

let htmlContent = '';
if (isAccessible) {
  htmlContent = parseMarkdown(doc!.content);
} else {
  Astro.response.status = 404;
}

Astro.response.headers.set(
  'Cache-Control',
  isAccessible && doc!.visibility === 'public'
    ? 'public, max-age=60, s-maxage=300, stale-while-revalidate=600'
    : 'private, no-store, no-transform',
);

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
};

const displayName = userObj?.name || userObj?.username || username;

const normalizeHttpUrl = (value: string | null | undefined): string | null => {
  if (!value) return null;
  const candidate = value.trim();
  if (!candidate) return null;
  try {
    const parsed = new URL(candidate.includes('://') ? candidate : `https://${candidate}`);
    return parsed.protocol === 'http:' || parsed.protocol === 'https:' ? parsed.toString() : null;
  } catch {
    return null;
  }
};

const getSocialUrl = (platform: string, value: string | null | undefined): string | null => {
  if (!value) return null;
  const val = value.trim();
  if (val.startsWith('http://') || val.startsWith('https://')) {
    return val;
  }
  const handle = val.startsWith('@') ? val.substring(1) : val;
  switch (platform) {
    case 'facebook':
      return `https://facebook.com/${handle}`;
    case 'instagram':
      return `https://instagram.com/${handle}`;
    case 'twitter':
      return `https://x.com/${handle}`;
    case 'linkedin':
      return `https://linkedin.com/in/${handle}`;
    case 'bluesky':
      return `https://bsky.app/profile/${handle}`;
    case 'mastodon':
      if (handle.includes('@')) {
        const parts = handle.split('@');
        if (parts.length === 2) return `https://${parts[1]}/@${parts[0]}`;
      }
      return `https://mastodon.social/@${handle}`;
    default:
      return val;
  }
};

// Build JSON-LD metadata for search engines
const sameAs: string[] = [];
if (userObj) {
  userObj.website = normalizeHttpUrl(userObj.website);
  userObj.facebook = getSocialUrl('facebook', userObj.facebook);
  userObj.instagram = getSocialUrl('instagram', userObj.instagram);
  userObj.twitter = getSocialUrl('twitter', userObj.twitter);
  userObj.linkedin = getSocialUrl('linkedin', userObj.linkedin);
  userObj.mastodon = getSocialUrl('mastodon', userObj.mastodon);
  userObj.bluesky = getSocialUrl('bluesky', userObj.bluesky);

  if (userObj.website) sameAs.push(userObj.website);
  if (userObj.facebook) sameAs.push(userObj.facebook);
  if (userObj.instagram) sameAs.push(userObj.instagram);
  if (userObj.twitter) sameAs.push(userObj.twitter);
  if (userObj.linkedin) sameAs.push(userObj.linkedin);
  if (userObj.mastodon) sameAs.push(userObj.mastodon);
  if (userObj.bluesky) sameAs.push(userObj.bluesky);
}

const jsonLd = isAccessible
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: doc!.title,
      description:
        doc!.description || `Read "${doc!.title}" by ${displayName} on ${config.appName}.`,
      datePublished: new Date(doc!.createdAt).toISOString(),
      dateModified: new Date(doc!.updatedAt).toISOString(),
      author: {
        '@type': 'Person',
        name: displayName,
        url: new URL(`/${username}`, Astro.url.origin).toString(),
        ...(sameAs.length > 0 ? { sameAs: sameAs } : {}),
      },
      publisher: {
        '@type': 'Organization',
        name: config.appName,
        logo: {
          '@type': 'ImageObject',
          url: new URL(config.appIcon || '/favicon.svg', Astro.url.origin).toString(),
        },
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': Astro.url.href,
      },
      image: new URL(config.appIcon || '/favicon.svg', Astro.url.origin).toString(),
    }
  : undefined;
---

<Layout
  title={isAccessible ? `${doc!.title} - ${displayName}` : `Access Restricted - ${config.appName}`}
  description={isAccessible
    ? (doc!.description || `Read "${doc!.title}" by ${displayName} on ${config.appName}.`)
    : undefined}
  keywords={isAccessible ? doc!.tags || undefined : undefined}
  authorName={isAccessible ? displayName : undefined}
  robots={isAccessible && doc!.visibility === 'unlisted' ? 'noindex, nofollow' : undefined}
  jsonLd={jsonLd}
>
  <main class="min-h-screen bg-bg-app text-text-main flex flex-col">
    {!isAccessible ? (
      <div class="grow flex flex-col items-center justify-center p-6 text-center select-none">
        <div class="w-16 h-16 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-500 mb-4 animate-pulse">
          <ShieldAlert className="w-8 h-8" />
        </div>
        <h1 class="text-xl font-bold mb-2">Restricted Document Access</h1>
        <p class="text-sm text-text-muted max-w-sm mb-6">
          This document is private or could not be found. Make sure the URL is correct and the owner has enabled public sharing.
        </p>
        <a href={`/${username}`} class="px-6 py-2.5 rounded-lg bg-text-main text-bg-card font-bold text-xs hover:opacity-90 transition-all shadow">
          View {displayName}'s Profile
        </a>
      </div>
    ) : (
      <>
        {/* Header bar */}
        <header class="no-print border-b border-border-custom bg-bg-card px-3 py-3 sm:px-4 md:px-6">
          <div class="mx-auto flex w-full max-w-6xl flex-col gap-3 md:flex-row md:items-center md:justify-between">
            <div class="flex min-w-0 items-center gap-2 sm:gap-3">
            {config.appLogo ? (
              <img src={config.appLogo} alt={config.appName} class="h-5 w-auto max-w-[11rem] shrink-0 object-contain sm:h-6 md:max-w-none" />
            ) : (
              <div class="w-6 h-6 rounded bg-text-main flex items-center justify-center text-bg-card font-black text-sm shrink-0">
                {config.appName.substring(0, 1).toUpperCase()}
              </div>
            )}
              <span class="truncate text-xs font-extrabold tracking-wider sm:text-sm">{config.appName.toUpperCase()}</span>
              <span class="hidden text-border-custom/60 select-none sm:inline">&middot;</span>
              <span class="truncate text-2xs font-semibold text-text-muted sm:hidden">@{username}</span>
              <span class="hidden text-text-muted md:inline">/</span>
              <a
                href={`/${username}`}
                class="hidden min-w-0 truncate text-xs font-semibold text-text-muted transition-colors hover:text-text-main sm:inline"
              >
                @{username}
              </a>
            </div>

            <div class="flex flex-wrap items-center gap-2 sm:justify-end">
              <span class="rounded-md bg-border-custom/40 px-2 py-1 text-3xs font-semibold text-text-muted">
                Read-Only
              </span>
              <button
                onclick="window.print()"
                class="inline-flex items-center gap-1.5 rounded-lg border border-border-custom bg-bg-card px-2.5 py-1.5 text-xs font-semibold transition-all hover:bg-border-custom/30 cursor-pointer sm:px-3"
                title="Print Document"
              >
                <Printer className="w-3.5 h-3.5" />
                <span class="sm:hidden">Print</span>
                <span class="hidden sm:inline">Print / PDF</span>
              </button>
              <button
                id="theme-toggle"
                class="rounded-lg border border-border-custom bg-bg-card p-2 text-text-muted transition-all hover:bg-border-custom/25 hover:text-text-main cursor-pointer"
                title="Toggle Theme"
                aria-label="Toggle Theme"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
              </button>
            </div>
          </div>
        </header>

        {/* Paper canvas */}
        <div class="print-container flex grow justify-center overflow-y-auto px-2 py-3 sm:p-4 md:p-8">
          <article class="word-paper print-container flex w-full max-w-4xl flex-col rounded-none px-4 py-6 sm:rounded-lg sm:px-6 sm:py-8 md:px-16 md:py-12">
            <h1 class="mb-1 border-b border-border-custom/40 pb-4 text-2xl font-extrabold tracking-tight sm:text-3xl md:text-4xl">
              {doc!.title || 'Untitled Document'}
            </h1>

            <div class="no-print mt-2 mb-6 flex flex-col gap-2 text-3xs text-text-muted select-none sm:mb-8 sm:flex-row sm:flex-wrap sm:items-center sm:gap-3">
              <span class="flex flex-wrap items-center gap-1">
                By
                <a href={`/${username}`} class="font-bold text-text-main hover:underline">
                  {displayName}
                </a>
              </span>
              <span class="hidden sm:inline">&middot;</span>
              <span class="leading-relaxed">
                Last updated: <span class="font-semibold">{formatDate(new Date(doc!.updatedAt))}</span>
              </span>
            </div>

            <div class="public-document-content ProseMirror prose max-w-none grow" set:html={htmlContent} />
          </article>
        </div>
      </>
    )}
  </main>

  <script is:inline data-cfasync="false">
    const themeBtn = document.getElementById('theme-toggle');
    if (themeBtn) {
      themeBtn.addEventListener('click', () => {
        const cl = document.documentElement.classList;
        const next = cl.contains('light') ? 'dark' : 'light';
        cl.remove('light', 'dark');
        cl.add(next);
        localStorage.setItem('theme', next);
      });
    }
  </script>
</Layout>
