---
export const prerender = false;

import { and, eq, like, or, sql } from 'drizzle-orm';
import Footer from '@/components/Footer.astro';
import { getDB } from '@/db';
import Layout from '@/layouts/Layout.astro';
import { config } from '@/utils/config';
import { homeConfig } from '@/utils/homeConfig';

const { db, users, documents, dialect } = await getDB();
const user = Astro.locals.user;
const isLoggedIn = !!user;

const searchQuery = Astro.url.searchParams.get('q') || '';
const isFeaturedValue = dialect === 'mysql' ? 1 : true;

let featuredUsers: any[] = [];
let errorMsg = null;

try {
  featuredUsers = await db
    .select({
      id: users.id,
      username: users.username,
      name: users.name,
      website: users.website,
      facebook: users.facebook,
      instagram: users.instagram,
      twitter: users.twitter,
      linkedin: users.linkedin,
      mastodon: users.mastodon,
      bluesky: users.bluesky,
      publicDocsCount:
        sql<number>`count(case when ${documents.visibility} = 'public' then 1 else null end)`.mapWith(
          Number,
        ),
    })
    .from(users)
    .leftJoin(documents, eq(users.id, documents.userId))
    .where(
      searchQuery
        ? and(
            eq(users.isFeatured, isFeaturedValue),
            or(like(users.username, `%${searchQuery}%`), like(users.name, `%${searchQuery}%`)),
          )
        : eq(users.isFeatured, isFeaturedValue),
    )
    .groupBy(
      users.id,
      users.username,
      users.name,
      users.website,
      users.facebook,
      users.instagram,
      users.twitter,
      users.linkedin,
      users.mastodon,
      users.bluesky,
    );
} catch (err) {
  console.error('Failed to query featured users with count, trying fallback:', err);
  try {
    const rawUsers = await db
      .select()
      .from(users)
      .where(
        searchQuery
          ? and(
              eq(users.isFeatured, isFeaturedValue),
              or(like(users.username, `%${searchQuery}%`), like(users.name, `%${searchQuery}%`)),
            )
          : eq(users.isFeatured, isFeaturedValue),
      );
    featuredUsers = await Promise.all(
      rawUsers.map(async (u: any) => {
        const docs = await db
          .select({ id: documents.id })
          .from(documents)
          .where(and(eq(documents.userId, u.id), eq(documents.visibility, 'public')));
        return {
          id: u.id,
          username: u.username,
          name: u.name,
          website: u.website,
          facebook: u.facebook,
          instagram: u.instagram,
          twitter: u.twitter,
          linkedin: u.linkedin,
          mastodon: u.mastodon,
          bluesky: u.bluesky,
          publicDocsCount: docs.length,
        };
      }),
    );
  } catch (fallbackErr) {
    console.error('Fallback query failed as well:', fallbackErr);
    errorMsg = 'An error occurred while loading featured workspaces.';
  }
}
---

<Layout title={`${config.appName} - Share and Organize Documents`} description={config.appDescription}>
  <!-- Top sticky header -->
  <header class="sticky top-0 z-50 backdrop-blur-md bg-bg-card/85 border-b border-border-custom transition-all select-none">
    <div class="max-w-6xl mx-auto px-4 h-15 flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 font-black text-base tracking-tight text-text-main group">
        {config.appLogo ? (
          <img src={config.appLogo} alt={config.appName} class="h-6.5 w-auto object-contain transition-all group-hover:scale-[1.02]" />
        ) : (
          <span class="w-6.5 h-6.5 bg-text-main text-bg-card rounded-md flex items-center justify-center font-black text-sm transition-all group-hover:scale-[1.02]">
            {config.appName.substring(0, 1).toUpperCase()}
          </span>
        )}
        <span class="font-black">{config.appName}<span class="text-text-muted">.</span></span>
      </a>

      <!-- Right Nav Options -->
      <div class="flex items-center gap-3">
        <!-- Theme Switcher -->
        <button
          id="landing-theme-toggle"
          class="p-2 rounded-lg border border-border-custom hover:bg-border-custom/25 text-text-muted hover:text-text-main transition-all bg-bg-card cursor-pointer flex items-center justify-center shrink-0"
          aria-label="Toggle Theme"
        >
          <!-- Sun Icon -->
          <svg id="theme-sun-icon" class="w-4 h-4 hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="m4.93 4.93 1.41 1.41"></path>
            <path d="m17.66 17.66 1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="m6.34 17.66-1.41 1.41"></path>
            <path d="m19.07 4.93-1.41 1.41"></path>
          </svg>
          <!-- Moon Icon -->
          <svg id="theme-moon-icon" class="w-4 h-4 hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
          </svg>
        </button>

        {isLoggedIn ? (
          <a
            href="/documents"
            class="px-4 py-2 rounded-lg bg-text-main text-bg-card font-bold hover:opacity-90 active:scale-[0.98] transition-all text-xs flex items-center gap-1.5 cursor-pointer shadow-sm"
          >
            Go to Workspace
            <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
        ) : (
          <div class="flex items-center gap-1.5">
            <a
              href="/login"
              class="px-3.5 py-2 rounded-lg border border-border-custom hover:bg-border-custom/25 font-bold text-xs text-text-main transition-all cursor-pointer"
            >
              Sign In
            </a>
            <a
              href="/register"
              class="px-3.5 py-2 rounded-lg bg-text-main text-bg-card font-bold hover:opacity-90 active:scale-[0.98] transition-all text-xs cursor-pointer shadow-sm"
            >
              Register
            </a>
          </div>
        )}
      </div>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-4 py-16 md:py-24 space-y-20">
    <!-- Hero / Intro -->
    <section class="text-center max-w-2xl mx-auto space-y-6">
      <h1 class="text-4xl md:text-5xl font-black tracking-tight text-text-main leading-tight select-none">
        {homeConfig.heroTitle}
      </h1>
      <p class="text-sm md:text-base text-text-muted leading-relaxed select-none">
        {homeConfig.heroSubtitle}
      </p>

      <!-- Search Box -->
      <div class="pt-4 max-w-lg mx-auto">
        <form method="GET" action="/" class="relative flex items-center gap-2">
          <div class="relative flex-1">
            <span class="absolute inset-y-0 left-3.5 flex items-center pointer-events-none">
              <svg class="w-4 h-4 text-text-muted" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.3-4.3"></path>
              </svg>
            </span>
            <input
              type="text"
              name="q"
              value={searchQuery}
              placeholder="Search workspaces by name or username..."
              class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-border-custom bg-bg-card text-text-main outline-none focus:ring-1 focus:ring-text-main focus:border-text-main text-xs font-semibold placeholder:text-text-muted transition-all shadow-2xs"
            />
            {searchQuery && (
              <a
                href="/"
                class="absolute inset-y-0 right-3 flex items-center text-text-muted hover:text-text-main transition-colors text-3xs font-bold"
                title="Clear Search"
              >
                Clear
              </a>
            )}
          </div>
          <button
            type="submit"
            class="px-4 py-2.5 rounded-xl bg-text-main text-bg-card font-bold hover:opacity-90 transition-all text-xs cursor-pointer shadow-sm shrink-0"
          >
            Search
          </button>
        </form>
      </div>
    </section>

    <!-- Divider -->
    <hr class="border-border-custom" />

    <!-- Directory Section -->
    <section class="space-y-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 select-none">
        <div>
          <h2 class="text-lg font-black text-text-main tracking-tight">{homeConfig.directoryTitle}</h2>
          <p class="text-3xs text-text-muted mt-0.5 font-medium">
            {homeConfig.directorySubtitle}
          </p>
        </div>
        {searchQuery && (
          <div class="text-3xs font-semibold text-text-muted bg-border-custom/30 px-2.5 py-1.5 rounded-lg border border-border-custom">
            Showing results for "<span class="text-text-main font-bold">{searchQuery}</span>"
          </div>
        )}
      </div>

      {errorMsg ? (
        <div class="p-8 text-center rounded-xl border border-border-custom bg-bg-card max-w-md mx-auto space-y-2">
          <p class="text-xs font-bold text-text-main">{errorMsg}</p>
          <a href="/" class="inline-block text-3xs font-bold text-text-muted hover:text-text-main hover:underline">Try reloading</a>
        </div>
      ) : featuredUsers.length === 0 ? (
        <div class="py-16 text-center rounded-xl border border-border-custom bg-bg-card/40 max-w-md mx-auto space-y-4">
          <div class="w-12 h-12 rounded-full border border-border-custom flex items-center justify-center mx-auto bg-bg-card select-none">
            <svg class="w-5 h-5 text-text-muted" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
          </div>
          <div class="space-y-1">
            <h3 class="text-xs font-bold text-text-main">No featured workspaces found</h3>
            <p class="text-3xs text-text-muted max-w-[280px] mx-auto leading-normal">
              {searchQuery ? "We couldn't find any creators matching your search terms. Double check your spelling or try clearing the search." : "No creators have featured their workspaces yet. Be the first by opting-in through your settings!"}
            </p>
          </div>
          {searchQuery && (
            <a
              href="/"
              class="inline-block px-3.5 py-1.5 rounded-lg border border-border-custom hover:bg-border-custom/25 font-bold text-3xs text-text-main transition-all"
            >
              Clear Search Query
            </a>
          )}
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredUsers.map((creator) => (
            <div class="group flex flex-col justify-between p-5 rounded-2xl border border-border-custom bg-bg-card shadow-2xs hover:shadow-xs hover:border-text-main/20 hover:-translate-y-0.5 transition-all duration-300">
              <div class="space-y-4">
                <!-- User Meta -->
                <div class="flex items-start justify-between gap-3">
                  <div class="min-w-0">
                    <h3 class="font-black text-sm text-text-main truncate leading-tight group-hover:text-text-main transition-colors">
                      {creator.name || creator.username}
                    </h3>
                    <p class="font-mono text-3xs text-text-muted mt-0.5 select-all">@{creator.username}</p>
                  </div>
                  <!-- Public count badge -->
                  <span class="shrink-0 text-3xs font-semibold bg-bg-app border border-border-custom text-text-muted px-2 py-0.5 rounded-md flex items-center gap-1 select-none">
                    <svg class="w-2.5 h-2.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path>
                      <polyline points="14 2 14 8 20 8"></polyline>
                    </svg>
                    {creator.publicDocsCount}
                  </span>
                </div>

                <!-- Social Handles (Horizontal Grid) -->
                {(creator.website || creator.twitter || creator.linkedin || creator.bluesky || creator.mastodon || creator.instagram || creator.facebook) && (
                  <div class="flex flex-wrap items-center gap-1.5 pt-1 border-t border-border-custom/50">
                    {creator.website && (
                      <a
                        href={creator.website.startsWith('http') ? creator.website : `https://${creator.website}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-1.5 rounded-lg border border-border-custom bg-bg-app text-text-muted hover:text-text-main transition-all hover:scale-105"
                        title="Website"
                      >
                        <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="12" r="10"></circle>
                          <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
                          <path d="M2 12h20"></path>
                        </svg>
                      </a>
                    )}
                    {creator.twitter && (
                      <a
                        href={`https://x.com/${creator.twitter.replace('@', '')}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-1.5 rounded-lg border border-border-custom bg-bg-app text-text-muted hover:text-text-main transition-all hover:scale-105"
                        title="Twitter / X"
                      >
                        <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M4 4l11.733 16h4.267l-11.733 -16z"></path>
                          <path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path>
                        </svg>
                      </a>
                    )}
                    {creator.linkedin && (
                      <a
                        href={creator.linkedin.startsWith('http') ? creator.linkedin : `https://linkedin.com/in/${creator.linkedin}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-1.5 rounded-lg border border-border-custom bg-bg-app text-text-muted hover:text-text-main transition-all hover:scale-105"
                        title="LinkedIn"
                      >
                        <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                          <rect x="2" y="9" width="4" height="12"></rect>
                          <circle cx="4" cy="4" r="2"></circle>
                        </svg>
                      </a>
                    )}
                    {creator.bluesky && (
                      <a
                        href={`https://bsky.app/profile/${creator.bluesky.replace('@', '')}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-1.5 rounded-lg border border-border-custom bg-bg-app text-text-muted hover:text-text-main transition-all hover:scale-105"
                        title="Bluesky"
                      >
                        <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M12 12c-2-2.67-4-4-6-4a4 4 0 0 0-4 4c0 3 3 5 6 8a18.23 18.23 0 0 0 4-8Z" />
                          <path d="M12 12c2-2.67 4-4 6-4a4 4 0 0 1 4 4c0 3-3 5-6 8a18.23 18.23 0 0 1-4-8Z" />
                        </svg>
                      </a>
                    )}
                    {creator.mastodon && (
                      <a
                        href={creator.mastodon.startsWith('http') ? creator.mastodon : `https://mastodon.social/@${creator.mastodon.replace('@', '')}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-1.5 rounded-lg border border-border-custom bg-bg-app text-text-muted hover:text-text-main transition-all hover:scale-105"
                        title="Mastodon"
                      >
                        <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M21 8c0-2.8-2-4-5-4H8C5 4 3 5.2 3 8v4c0 4.8 3 6 5 6h2c.7 0 1.3-.3 1.7-.8l.3-.4.3.4c.4.5 1 .8 1.7.8h2c2 0 5-1.2 5-6V8z"></path>
                          <path d="M8 11v-3"></path>
                          <path d="M12 11v-3"></path>
                          <path d="M16 11v-3"></path>
                        </svg>
                      </a>
                    )}
                    {creator.instagram && (
                      <a
                        href={`https://instagram.com/${creator.instagram.replace('@', '')}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-1.5 rounded-lg border border-border-custom bg-bg-app text-text-muted hover:text-text-main transition-all hover:scale-105"
                        title="Instagram"
                      >
                        <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                        </svg>
                      </a>
                    )}
                    {creator.facebook && (
                      <a
                        href={`https://facebook.com/${creator.facebook}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-1.5 rounded-lg border border-border-custom bg-bg-app text-text-muted hover:text-text-main transition-all hover:scale-105"
                        title="Facebook"
                      >
                        <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
                        </svg>
                      </a>
                    )}
                  </div>
                )}
              </div>

              <!-- Action button -->
              <div class="pt-5 mt-4 border-t border-border-custom/50">
                <a
                  href={`/${creator.username}`}
                  class="w-full flex items-center justify-center gap-1.5 py-2 rounded-xl border border-border-custom bg-bg-app text-xs font-bold text-text-muted hover:text-text-main hover:border-text-main/45 active:scale-[0.98] transition-all cursor-pointer"
                >
                  View Public Workspace
                  <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"></path>
                    <path d="m12 5 7 7-7 7"></path>
                  </svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      )}
    </section>
  </main>

  <Footer />

  <script is:inline data-cfasync="false">
    const toggleBtn = document.getElementById('landing-theme-toggle');
    const sunIcon = document.getElementById('theme-sun-icon');
    const moonIcon = document.getElementById('theme-moon-icon');

    const updateIcons = (theme) => {
      if (theme === 'dark') {
        sunIcon?.classList.remove('hidden');
        moonIcon?.classList.add('hidden');
      } else {
        sunIcon?.classList.add('hidden');
        moonIcon?.classList.remove('hidden');
      }
    };

    const currentTheme = localStorage.getItem('theme') || 'light';
    updateIcons(currentTheme);

    toggleBtn?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      const newTheme = isDark ? 'light' : 'dark';
      
      document.documentElement.classList.remove('light', 'dark');
      document.documentElement.classList.add(newTheme);
      localStorage.setItem('theme', newTheme);
      updateIcons(newTheme);
    });
  </script>
</Layout>
